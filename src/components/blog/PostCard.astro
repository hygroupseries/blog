---
/**
 * PostCard
 * ────────
 * Renders a single post summary in list views (home page, blog index,
 * tag pages).  No images — text and meta only, in keeping with the
 * text-first design goal.
 *
 * Props
 *   post  — a CollectionEntry<'blog'> from Astro Content Collections
 *
 * Usage
 *   <PostCard post={post} />
 */

import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';
import { formatDate, toISODate } from '../../utils/date';
import { getReadingTime } from '../../utils/reading-time';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, draft, featured } = post.data;

const href = `/blog/${post.id}`;
const readingTime = getReadingTime(post.body ?? '');
---

<article class="group py-8 border-b border-zinc-200 dark:border-zinc-800 last:border-b-0">
  {/* Draft / Featured badges */}
  {(draft || featured) && (
    <div class="flex gap-2 mb-3">
      {draft && (
        <span class="inline-block rounded px-2 py-0.5 text-xs font-medium
                     bg-amber-100 text-amber-700
                     dark:bg-amber-900/30 dark:text-amber-400">
          草稿
        </span>
      )}
      {featured && (
        <span class="inline-block rounded px-2 py-0.5 text-xs font-medium
                     bg-cyan-100 text-cyan-700
                     dark:bg-cyan-900/30 dark:text-cyan-400">
          精选
        </span>
      )}
    </div>
  )}

  {/* Title */}
  <h2 class="text-xl font-semibold leading-snug mb-2">
    <a
      href={href}
      class="text-zinc-900 dark:text-zinc-100
             hover:text-cyan-600 dark:hover:text-cyan-400
             transition-colors no-underline"
    >
      {title}
    </a>
  </h2>

  {/* Meta: date · reading time */}
  <div class="flex items-center gap-3 text-sm text-zinc-500 dark:text-zinc-400 mb-3">
    <time datetime={toISODate(pubDate)}>
      {formatDate(pubDate)}
    </time>
    <span aria-hidden="true">·</span>
    <span>{readingTime}阅读</span>
  </div>

  {/* Description */}
  {description && (
    <p class="text-zinc-600 dark:text-zinc-300 leading-relaxed mb-4 line-clamp-3">
      {description}
    </p>
  )}

  {/* Tags */}
  {tags.length > 0 && <TagList tags={tags} />}
</article>
