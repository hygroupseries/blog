---
/**
 * Header
 * ──────
 * Site-wide navigation bar.
 *
 * Features
 *   - Site name / home link on the left
 *   - Nav links on the right: Blog · Tags · About
 *   - Active link is highlighted based on the current pathname
 *   - Fully responsive — stacks gracefully on narrow viewports
 *   - No JavaScript required
 */

import { SITE } from '../../consts/site';

const navLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/tags', label: 'Tags' },
  { href: '/about', label: 'About' },
] as const;

/**
 * Determine whether a nav link should be marked as active.
 * The home link is only active on `/`; all others match on prefix
 * so that /blog/some-post still highlights the Blog link.
 */
function isActive(linkHref: string, pathname: string): boolean {
  if (linkHref === '/') return pathname === '/';
  return pathname === linkHref || pathname.startsWith(linkHref + '/');
}

const pathname = new URL(Astro.request.url).pathname;
---

<header class="sticky top-0 z-40 w-full border-b border-zinc-200 dark:border-zinc-800
               bg-white/90 dark:bg-zinc-950/90 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-3xl items-center justify-between px-4 sm:px-6 lg:px-8">

    {/* Site name / home link */}
    <a
      href="/"
      class="font-semibold text-zinc-900 dark:text-zinc-100
             hover:text-cyan-600 dark:hover:text-cyan-400
             transition-colors no-underline text-base tracking-tight"
      aria-label={`${SITE.name} — 首页`}
    >
      {SITE.name}
    </a>

    {/* Primary navigation */}
    <nav aria-label="主导航">
      <ul class="flex items-center gap-1">
        {navLinks.map(({ href, label }) => {
          const active = isActive(href, pathname);
          return (
            <li>
              <a
                href={href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'inline-block rounded px-3 py-1.5 text-sm font-medium transition-colors no-underline',
                  active
                    ? 'bg-zinc-100 dark:bg-zinc-800 text-zinc-900 dark:text-zinc-100'
                    : 'text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:text-zinc-900 dark:hover:text-zinc-100',
                ]}
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

  </div>
</header>
