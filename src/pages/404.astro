---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
---

<BaseLayout
  title="404 — 页面不存在"
  description="你访问的页面不存在或已被移动。"
>
  <Container class="py-24 text-center">

    <p class="text-8xl font-bold tabular-nums text-zinc-200 dark:text-zinc-800 select-none">
      404
    </p>

    <h1 class="mt-6 text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
      页面不存在
    </h1>

    <p class="mt-4 text-zinc-500 dark:text-zinc-400 max-w-sm mx-auto leading-relaxed">
      你访问的页面不存在，可能已被移动或删除。
    </p>

    <div class="mt-10 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href="/"
        class="inline-flex items-center rounded-md bg-zinc-900 dark:bg-zinc-100
               px-4 py-2 text-sm font-medium
               text-zinc-100 dark:text-zinc-900
               hover:bg-zinc-700 dark:hover:bg-zinc-300
               transition-colors no-underline"
      >
        回到首页
      </a>
      <a
        href="/blog"
        class="inline-flex items-center text-sm font-medium
               text-zinc-500 dark:text-zinc-400
               hover:text-cyan-600 dark:hover:text-cyan-400
               transition-colors no-underline"
      >
        浏览所有文章 →
      </a>
    </div>

  </Container>
</BaseLayout>
